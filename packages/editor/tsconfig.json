{
  "compilerOptions": {
    "composite": true,
    "target": "es2020",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@mavonengine/core": ["../core/src/index"],
      "@mavonengine/core/*": ["../core/src/*"]
    },
    "allowUmdGlobalAccess": true,
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "emitDeclarationOnly": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "references": [
    { "path": "../core" }
  ],
  "include": ["src", "e2e", "Global.d.ts"]
}
